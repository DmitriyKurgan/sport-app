# Production env для docker-compose.
# Скопируй в .env (в корне проекта, рядом с docker-compose.yml) и заполни секреты.

# === DB ===
DATABASE_NAME=fittrack
DATABASE_USER=postgres
DATABASE_PASSWORD=change-me-strong-password

# === JWT (обязательно!) ===
# Сгенерируй через: openssl rand -hex 32
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# === Web ===
# Куда web обращается за API (с точки зрения браузера пользователя)
NEXT_PUBLIC_API_URL=http://localhost:3001
# Откуда принимаем запросы на API (CORS)
CORS_ORIGIN=http://localhost:3000

# === Bcrypt ===
BCRYPT_ROUNDS=10

# === Опциональные: пробросы портов наружу ===
POSTGRES_EXPOSED_PORT=5432
REDIS_EXPOSED_PORT=6379
API_EXPOSED_PORT=3001
WEB_EXPOSED_PORT=3000

# === Reverse proxy (Caddy) ===
# CADDY_SITE — address блока:
#   ":80"           — local/staging без TLS (только HTTP)
#   "app.example.com" — Caddy сам получит сертификат от Let's Encrypt (нужны DNS A-запись и публичный IP)
CADDY_SITE=:80
ACME_EMAIL=admin@example.com
CADDY_HTTP_PORT=80
CADDY_HTTPS_PORT=443
