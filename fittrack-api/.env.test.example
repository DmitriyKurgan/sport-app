# Скопируй в .env.test и подставь свои значения.
# Используется для npm run test:e2e (требуется живая PG).

DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=fittrack_test
DATABASE_SYNCHRONIZE=false
DATABASE_LOGGING=false

JWT_ACCESS_SECRET=test-access-secret-256-bit-1234567890abcdef1234567890
JWT_REFRESH_SECRET=test-refresh-secret-256-bit-1234567890abcdef1234567890
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
BCRYPT_ROUNDS=4

REDIS_HOST=localhost
REDIS_PORT=6379
